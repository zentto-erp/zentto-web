PORT=4100
DB_SERVER=localhost
DB_DATABASE=BrokerDB
DB_USER=sa
DB_PASSWORD=change_me
DB_ENCRYPT=false
DB_TRUST_CERT=true
JWT_SECRET=change_me
JWT_EXPIRES=12h
REDIS_URL=
NODE_ENV=development

# Aggregator worker
AGGREGATOR_CRON_ENABLED=true
AGGREGATOR_CRON_SCHEDULE=0 */6 * * *
AGGREGATOR_RUN_ON_STARTUP=true
AGGREGATOR_STARTUP_DELAY_MS=5000
AGGREGATOR_PROVIDER=auto
AGGREGATOR_CITIES=New York,London,Paris,Tokyo,Madrid,Miami
AGGREGATOR_INVENTORY_TYPES=room,vehicle,boat,flight,train
AGGREGATOR_PLACE_PROVIDERS=geoapify,foursquare,tomtom,here,google,osm
AGGREGATOR_INVENTORY_PROVIDERS=booking,amadeus,simulated
AGGREGATOR_MAX_ITEMS_PER_CITY=25
AGGREGATOR_OSM_TIMEOUT_MS=18000
AGGREGATOR_OSM_COOLDOWN_MS=900

# Inventory providers (optional)
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_ENDPOINT=https://booking-com15.p.rapidapi.com/api/v1/hotels/searchHotels
RAPIDAPI_TIMEOUT_MS=12000
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
EXPEDIA_API_KEY=

# Places providers (optional)
GOOGLE_PLACES_API_KEY=
HERE_API_KEY=
TOMTOM_API_KEY=
FOURSQUARE_API_KEY=
GEOAPIFY_API_KEY=
