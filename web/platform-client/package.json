{
  "name": "@zentto/platform-client",
  "version": "0.5.0",
  "description": "Cliente tipado para los servicios de plataforma Zentto (notify, auth, cache, landing, events, webhooks). Uso oficial en ERP, verticals y sitios de tenants clientes.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./notify": {
      "types": "./dist/notify/index.d.ts",
      "import": "./dist/notify/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js"
    },
    "./landing": {
      "types": "./dist/landing/index.d.ts",
      "import": "./dist/landing/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js"
    }
  },
  "peerDependenciesMeta": {
    "kafkajs": { "optional": true }
  },
  "peerDependencies": {
    "kafkajs": "^2.2.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "zentto",
    "erp",
    "notify",
    "sdk",
    "platform"
  ],
  "author": "Zentto ERP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentto-erp/zentto-web.git",
    "directory": "web/platform-client"
  },
  "homepage": "https://zentto.net",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
