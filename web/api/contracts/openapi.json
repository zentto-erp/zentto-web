          "200": { "description": "OK" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "put": {
        "tags": ["Clientes"],
        "summary": "Actualiza cliente",
        "parameters": [{ "$ref": "#/components/parameters/CodigoParam" }],
        "requestBody": {
          "required": true,
