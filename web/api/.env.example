PORT=4000

# ── Motor de base de datos: "sqlserver" | "postgres" ──────────────────────────
DB_TYPE=sqlserver

# ── SQL Server ────────────────────────────────────────────────────────────────
DB_SERVER=DELLXEONE31545\\SQLEXPRESS
DB_DATABASE=DatqBoxExpress
DB_USER=sa
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_ENCRYPT=false
DB_TRUST_CERT=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=datqboxweb
PG_USER=postgres
PG_PASSWORD=YOUR_PG_PASSWORD_HERE
PG_POOL_MIN=0
PG_POOL_MAX=10
PG_SSL=false

# CORS — origenes permitidos en produccion (separados por coma)
# En desarrollo no hace falta (localhost ya esta incluido por defecto)
# CORS_ORIGINS=https://zentto.net,https://www.zentto.net,https://app.zentto.net

JWT_SECRET=change_me
JWT_EXPIRES=12h
REDIS_URL=

# Auth hardening
AUTH_PUBLIC_URL=http://localhost:3000
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_LOGIN_REQUIRE_CAPTCHA=false
AUTH_EXPOSE_DEBUG_LINKS=false
AUTH_VERIFY_TOKEN_MINUTES=1440
AUTH_RESET_TOKEN_MINUTES=30

# CAPTCHA (Turnstile/reCAPTCHA)
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET=
CAPTCHA_MIN_SCORE=0.5
# Optional override
# CAPTCHA_VERIFY_URL=

# ── Mail delivery via Zentto Notify (webhook) ─────────────────────────────────
# En produccion: apuntar a https://notify.zentto.net/api/email/send
# El token es el API_MASTER_KEY de zentto-notify
AUTH_MAIL_WEBHOOK_URL=
AUTH_MAIL_WEBHOOK_TOKEN=
MAIL_FROM=Zentto <no-reply@zentto.net>

# ── Ecommerce ─────────────────────────────────────────────────────────────────
STORE_URL=http://localhost:3000

# Media storage (images/articles/restaurant/POS)
MEDIA_STORAGE_PATH=./storage/media
MEDIA_PUBLIC_BASE_URL=http://localhost:4000
MEDIA_MAX_FILE_SIZE_MB=5

# ── Multi-tenant provisioning ──────────────────────────────
MASTER_API_KEY=change_me_very_long_secret_key_here
# Email del administrador que recibe el OTP de 2FA del backoffice
BACKOFFICE_ADMIN_EMAIL=admin@zentto.net

# ── Paddle Billing ─────────────────────────────────────────
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# ── Zentto Notify (emails de bienvenida) ───────────────────
NOTIFY_API_KEY=zntfy_...
NOTIFY_BASE_URL=https://notify.zentto.net

# ── Cloudflare DNS (creación automática de subdominios tenant) ──
CLOUDFLARE_EMAIL=gonzalezquijadaraulantonio@gmail.com
CLOUDFLARE_API_KEY=your_global_api_key_here
CLOUDFLARE_ZONE_ID=8959e90845cd162b15e4d0b7ee93ef9d
