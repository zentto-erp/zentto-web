{
  "name": "datqbox-modular-frontend",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "npx concurrently \"npm run dev:shell\" \"npm run dev:contabilidad\" \"npm run dev:nomina\" \"npm run dev:pos\" \"npm run dev:bancos\" \"npm run dev:inventario\" \"npm run dev:ventas\" \"npm run dev:compras\" \"npm run dev:restaurant\" \"npm run dev:ecommerce\" \"npm run dev:auditoria\"",
    "dev:shell": "npm --workspace @datqbox/shell run dev",
    "build:shell": "npm --workspace @datqbox/shell run build",
    "start:shell": "npm --workspace @datqbox/shell run start",
    "dev:nomina": "npm --workspace @datqbox/nomina run dev",
    "build:nomina": "npm --workspace @datqbox/nomina run build",
    "start:nomina": "npm --workspace @datqbox/nomina run start",
    "dev:contabilidad": "npm --workspace @datqbox/contabilidad run dev",
    "build:contabilidad": "npm --workspace @datqbox/contabilidad run build",
    "start:contabilidad": "npm --workspace @datqbox/contabilidad run start",
    "dev:pos": "npm --workspace @datqbox/pos run dev",
    "build:pos": "npm --workspace @datqbox/pos run build",
    "start:pos": "npm --workspace @datqbox/pos run start",
    "dev:bancos": "npm --workspace @datqbox/bancos run dev",
    "build:bancos": "npm --workspace @datqbox/bancos run build",
    "start:bancos": "npm --workspace @datqbox/bancos run start",
    "dev:inventario": "npm --workspace @datqbox/inventario run dev",
    "build:inventario": "npm --workspace @datqbox/inventario run build",
    "start:inventario": "npm --workspace @datqbox/inventario run start",
    "dev:ventas": "npm --workspace @datqbox/ventas run dev",
    "build:ventas": "npm --workspace @datqbox/ventas run build",
    "start:ventas": "npm --workspace @datqbox/ventas run start",
    "dev:compras": "npm --workspace @datqbox/compras run dev",
    "build:compras": "npm --workspace @datqbox/compras run build",
    "start:compras": "npm --workspace @datqbox/compras run start",
    "dev:restaurant": "npm --workspace @datqbox/restaurant run dev",
    "build:restaurant": "npm --workspace @datqbox/restaurant run build",
    "start:restaurant": "npm --workspace @datqbox/restaurant run start",
    "dev:ecommerce": "npm --workspace @datqbox/ecommerce run dev",
    "build:ecommerce": "npm --workspace @datqbox/ecommerce run build",
    "start:ecommerce": "npm --workspace @datqbox/ecommerce run start",
    "dev:auditoria": "npm --workspace @datqbox/auditoria run dev",
    "build:auditoria": "npm --workspace @datqbox/auditoria run build",
    "start:auditoria": "npm --workspace @datqbox/auditoria run start"
  },
  "overrides": {
    "title": "4.0.1",
    "clipboardy": "4.0.0",
    "execa": "8.0.1",
    "cross-spawn": "7.0.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23"
  }
}