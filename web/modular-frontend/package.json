{
  "name": "zentto-modular-frontend",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:setup": "npm run env:sync && npm run dev:all",
    "env:sync": "node scripts/sync-env-local.mjs",
    "build:all": "npm run build:shell && npm run build:contabilidad && npm run build:nomina && npm run build:pos && npm run build:bancos && npm run build:inventario && npm run build:ventas && npm run build:compras && npm run build:restaurant && npm run build:ecommerce && npm run build:auditoria && npm run build:logistica && npm run build:crm && npm run build:manufactura && npm run build:flota && npm run build:shipping",
    "start:all": "npx concurrently \"npm run start:shell\" \"npm run start:contabilidad\" \"npm run start:nomina\" \"npm run start:pos\" \"npm run start:bancos\" \"npm run start:inventario\" \"npm run start:ventas\" \"npm run start:compras\" \"npm run start:restaurant\" \"npm run start:ecommerce\" \"npm run start:auditoria\"",
    "dev:all": "npx concurrently \"npm run dev:shell\" \"npm run dev:contabilidad\" \"npm run dev:nomina\" \"npm run dev:pos\" \"npm run dev:bancos\" \"npm run dev:inventario\" \"npm run dev:ventas\" \"npm run dev:compras\" \"npm run dev:restaurant\" \"npm run dev:ecommerce\" \"npm run dev:auditoria\"",
    "dev:all:3011": "npx concurrently \"npm run dev:shell:3011\" \"npm run dev:contabilidad\" \"npm run dev:nomina\" \"npm run dev:pos\" \"npm run dev:bancos\" \"npm run dev:inventario\" \"npm run dev:ventas\" \"npm run dev:compras\" \"npm run dev:restaurant\" \"npm run dev:ecommerce\" \"npm run dev:auditoria\"",
    "dev:shell": "npm --workspace @zentto/shell run dev",
    "dev:shell:3011": "npm --workspace @zentto/shell run dev -- -p 3011",
    "build:shell": "npm --workspace @zentto/shell run build",
    "start:shell": "npm --workspace @zentto/shell run start",
    "dev:nomina": "npm --workspace @zentto/nomina run dev",
    "build:nomina": "npm --workspace @zentto/nomina run build",
    "start:nomina": "npm --workspace @zentto/nomina run start",
    "dev:contabilidad": "npm --workspace @zentto/contabilidad run dev",
    "build:contabilidad": "npm --workspace @zentto/contabilidad run build",
    "start:contabilidad": "npm --workspace @zentto/contabilidad run start",
    "dev:pos": "npm --workspace @zentto/pos run dev",
    "build:pos": "npm --workspace @zentto/pos run build",
    "start:pos": "npm --workspace @zentto/pos run start",
    "dev:bancos": "npm --workspace @zentto/bancos run dev",
    "build:bancos": "npm --workspace @zentto/bancos run build",
    "start:bancos": "npm --workspace @zentto/bancos run start",
    "dev:inventario": "npm --workspace @zentto/inventario run dev",
    "build:inventario": "npm --workspace @zentto/inventario run build",
    "start:inventario": "npm --workspace @zentto/inventario run start",
    "dev:ventas": "npm --workspace @zentto/ventas run dev",
    "build:ventas": "npm --workspace @zentto/ventas run build",
    "start:ventas": "npm --workspace @zentto/ventas run start",
    "dev:compras": "npm --workspace @zentto/compras run dev",
    "build:compras": "npm --workspace @zentto/compras run build",
    "start:compras": "npm --workspace @zentto/compras run start",
    "dev:restaurant": "npm --workspace @zentto/restaurante run dev",
    "build:restaurant": "npm --workspace @zentto/restaurante run build",
    "start:restaurant": "npm --workspace @zentto/restaurante run start",
    "dev:ecommerce": "npm --workspace @zentto/ecommerce run dev",
    "build:ecommerce": "npm --workspace @zentto/ecommerce run build",
    "start:ecommerce": "npm --workspace @zentto/ecommerce run start",
    "dev:auditoria": "npm --workspace @zentto/auditoria run dev",
    "build:auditoria": "npm --workspace @zentto/auditoria run build",
    "start:auditoria": "npm --workspace @zentto/auditoria run start",
    "dev:logistica": "npm --workspace @zentto/logistica run dev",
    "build:logistica": "npm --workspace @zentto/logistica run build",
    "start:logistica": "npm --workspace @zentto/logistica run start",
    "dev:crm": "npm --workspace @zentto/crm run dev",
    "build:crm": "npm --workspace @zentto/crm run build",
    "start:crm": "npm --workspace @zentto/crm run start",
    "dev:manufactura": "npm --workspace @zentto/manufactura run dev",
    "build:manufactura": "npm --workspace @zentto/manufactura run build",
    "start:manufactura": "npm --workspace @zentto/manufactura run start",
    "dev:flota": "npm --workspace @zentto/flota run dev",
    "build:flota": "npm --workspace @zentto/flota run build",
    "start:flota": "npm --workspace @zentto/flota run start",
    "dev:shipping": "npm --workspace @zentto/app-shipping run dev",
    "build:shipping": "npm --workspace @zentto/app-shipping run build",
    "start:shipping": "npm --workspace @zentto/app-shipping run start"
  },
  "overrides": {
    "title": "4.0.1",
    "clipboardy": "4.0.0",
    "execa": "8.0.1",
    "cross-spawn": "7.0.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23"
  },
  "dependencies": {
    "@zentto/datagrid": "^1.2.0",
    "@zentto/datagrid-core": "^1.2.0",
    "qrcode-generator": "^2.0.4"
  }
}
