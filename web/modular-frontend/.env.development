# ── API Backend ──────────────────────────────────────────────────────────────

# Produccion (servidor Hetzner — base de datos PostgreSQL real)
NEXT_PUBLIC_BACKEND_URL=https://api.zentto.net
NEXT_PUBLIC_API_BASE=https://api.zentto.net
NEXT_PUBLIC_API_URL=https://api.zentto.net
NEXT_PUBLIC_API_BASE_URL=https://api.zentto.net
BACKEND_URL=https://api.zentto.net
API_URL=https://api.zentto.net

# Local (descomenta si corres la API localmente con Docker o npm run dev)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
# NEXT_PUBLIC_API_BASE=http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# BACKEND_URL=http://localhost:4000
# API_URL=http://localhost:4000

# ── Auth ─────────────────────────────────────────────────────────────────────
