{
  "name": "@zentto/design-tokens",
  "version": "0.1.0",
  "description": "Zentto design tokens — source of truth for MUI + Tailwind v4 (ADR-NOTIFY-001 Opción C).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./css": "./dist/tokens.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/emit-css.cjs",
    "build:css": "node scripts/emit-css.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "zentto",
    "design-tokens",
    "mui",
    "tailwind",
    "design-system"
  ],
  "author": "Zentto ERP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentto-erp/zentto-web.git",
    "directory": "web/modular-frontend/packages/design-tokens"
  },
  "homepage": "https://zentto.net",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
