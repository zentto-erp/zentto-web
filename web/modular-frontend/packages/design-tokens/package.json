{
  "name": "@zentto/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Zentto design tokens — source of truth for MUI + Tailwind v4 (ADR-NOTIFY-001 Opción C).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./css": "./dist/tokens.css",
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/emit-css.cjs",
    "build:css": "node scripts/emit-css.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
