{
  "name": "@zentto/landing-kit",
  "version": "2.1.0-beta.4",
  "description": "Zentto Landing Kit — componentes enterprise B2B SaaS portables (Hero, TrustBar, FeatureGrid, PricingSection, ...) + runtime renderer de schemas JSON (v2.0) + infraestructura de blog. Base compartida para landings verticales (tickets, hotel, medical, restaurante, education, inmobiliario, rental).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "default": "./dist/metadata.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "default": "./dist/renderer/index.js"
    },
    "./blog": {
      "types": "./dist/blog/index.d.ts",
      "default": "./dist/blog/index.js"
    }
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "DESIGN.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node scripts/smoke-test.cjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build && npm run smoke"
  },
  "keywords": [
    "zentto",
    "landing",
    "marketing",
    "enterprise",
    "b2b",
    "saas",
    "mui",
    "next",
    "renderer",
    "cms"
  ],
  "author": "Zentto ERP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentto-erp/zentto-web.git",
    "directory": "web/modular-frontend/packages/landing-kit"
  },
  "homepage": "https://zentto.net",
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "@mui/icons-material": ">=5",
    "@mui/material": ">=5",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18",
    "zod": ">=3.22",
    "react-markdown": ">=9",
    "remark-gfm": ">=4",
    "rehype-sanitize": ">=6"
  },
  "peerDependenciesMeta": {
    "react-markdown": { "optional": true },
    "remark-gfm": { "optional": true },
    "rehype-sanitize": { "optional": true }
  },
  "devDependencies": {
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "next": "^14",
    "react": "^18",
    "typescript": "^5",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  }
}
